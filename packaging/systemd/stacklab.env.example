# Canonical managed root
STACKLAB_ROOT=/opt/stacklab

# SQLite and runtime state
STACKLAB_DATA_DIR=/var/lib/stacklab

# Bind locally when fronted by a reverse proxy
STACKLAB_HTTP_ADDR=127.0.0.1:8080

# Logging
STACKLAB_LOG_LEVEL=info

# Stable writable home for Compose and service runtime
HOME=/var/lib/stacklab/home
DOCKER_CONFIG=/var/lib/stacklab/docker

# Optional Docker daemon admin apply helper
# STACKLAB_DOCKER_ADMIN_HELPER_PATH=/usr/lib/stacklab/bin/stacklab-docker-admin-helper
# STACKLAB_DOCKER_ADMIN_USE_SUDO=true
# STACKLAB_DOCKER_ADMIN_BACKUP_DIR=/var/lib/stacklab/docker-admin

# Optional workspace permission repair helper
# STACKLAB_WORKSPACE_ADMIN_HELPER_PATH=/usr/lib/stacklab/bin/stacklab-workspace-admin-helper
# STACKLAB_WORKSPACE_ADMIN_USE_SUDO=true

# Optional Stacklab self-update helper
# STACKLAB_SELF_UPDATE_HELPER_PATH=/usr/lib/stacklab/bin/stacklab-self-update-helper
# STACKLAB_SELF_UPDATE_USE_SUDO=true
# STACKLAB_SELF_UPDATE_PACKAGE_NAME=stacklab
# STACKLAB_SELF_UPDATE_HEALTH_URL=http://127.0.0.1:8080/api/health

# Optional first-run bootstrap password
# STACKLAB_BOOTSTRAP_PASSWORD=change-me
