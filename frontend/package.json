{
  "name": "stacklab-frontend",
  "private": true,
  "version": "0.0.0",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": "24.18.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host 127.0.0.1 --port 5173",
    "generate": "npm run generate:api",
    "generate:api": "openapi-typescript ../docs/api/openapi.yaml --output src/lib/api-contract.generated.ts --alphabetize --support-array-length",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "lint": "eslint . --max-warnings=0",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "screenshots:readme": "node scripts/capture-readme-screenshots.mjs"
  },
  "dependencies": {
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/state": "^6.7.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.5",
    "@fontsource-variable/inter": "5.2.8",
    "@fontsource-variable/jetbrains-mono": "5.2.8",
    "@fontsource-variable/space-grotesk": "5.2.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.2",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "openapi-typescript": "6.7.6",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.2",
    "vitest": "^4.1.9"
  }
}
