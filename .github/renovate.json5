{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
  ],
  timezone: 'Europe/Warsaw',
  labels: [
    'dependencies',
  ],
  dependencyDashboard: true,
  assigneesFromCodeOwners: false,
  automerge: true,
  automergeType: 'pr',
  automergeStrategy: 'rebase',
  // Release train: stable goes out on day 1, dependency updates merge early in the month,
  // then nightly builds soak until the next stable release.
  automergeSchedule: [
    '* * 2-3 * *',
  ],
  platformAutomerge: false,
  prConcurrentLimit: 0,
  prHourlyLimit: 0,
  rebaseWhen: 'behind-base-branch',
  rangeStrategy: 'bump',
  customManagers: [
    {
      customType: 'regex',
      description: 'Update pinned Go analysis tools used by GitHub Actions.',
      fileMatch: [
        '^\\.github/workflows/advisory-static-analysis\\.yml$',
      ],
      matchStrings: [
        'go run (?<depName>honnef\\.co/go/tools)/cmd/staticcheck@(?<currentValue>v\\d+\\.\\d+\\.\\d+)',
        'go run (?<depName>golang\\.org/x/vuln)/cmd/govulncheck@(?<currentValue>v\\d+\\.\\d+\\.\\d+)',
      ],
      datasourceTemplate: 'go',
    },
  ],
  packageRules: [
    {
      description: 'Group frontend runtime dependencies into one reviewable PR.',
      matchManagers: [
        'npm',
      ],
      matchFileNames: [
        'frontend/package.json',
      ],
      matchDepTypes: [
        'dependencies',
      ],
      groupName: 'frontend runtime dependencies',
      groupSlug: 'frontend-runtime',
    },
    {
      description: 'Group frontend devDependencies into one tooling PR.',
      matchManagers: [
        'npm',
      ],
      matchFileNames: [
        'frontend/package.json',
      ],
      matchDepTypes: [
        'devDependencies',
      ],
      groupName: 'frontend dev dependencies',
      groupSlug: 'frontend-dev',
    },
    {
      description: 'Keep high-risk Go runtime modules ungrouped.',
      matchManagers: [
        'gomod',
      ],
      matchPackageNames: [
        'github.com/creack/pty',
        'github.com/gorilla/websocket',
        'modernc.org/sqlite',
      ],
      groupName: null,
      automerge: false,
    },
    {
      description: 'Group non-high-risk Go module updates into a single PR.',
      matchManagers: [
        'gomod',
      ],
      groupName: 'go dependencies',
      groupSlug: 'go-dependencies',
      matchPackageNames: [
        '!github.com/creack/pty',
        '!github.com/gorilla/websocket',
        '!modernc.org/sqlite',
      ],
    },
    {
      description: 'Group low-risk GitHub Actions updates into one PR.',
      matchManagers: [
        'github-actions',
      ],
      matchPackageNames: [
        'actions/checkout',
        'actions/setup-go',
        'actions/setup-node',
      ],
      groupName: 'low-risk github actions',
      groupSlug: 'github-actions-low-risk',
    },
    {
      description: 'Group remaining GitHub Actions updates into one PR.',
      matchManagers: [
        'github-actions',
      ],
      matchPackageNames: [
        '!actions/checkout',
        '!actions/setup-go',
        '!actions/setup-node',
      ],
      groupName: 'github actions',
      groupSlug: 'github-actions',
    },
    {
      description: 'Keep major updates separate.',
      matchUpdateTypes: [
        'major',
      ],
      groupName: null,
      automerge: false,
    },
    {
      description: 'Require review for all GitHub Actions updates.',
      matchManagers: [
        'github-actions',
      ],
      automerge: false,
    },
  ],
}
